<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Equinor.OsduCsharpClient and Equinor.Osdu.Schemas are published to GitHub Packages.
         Credentials live in your user-level NuGet config (a PAT with read:packages),
         not in this file. See README. -->
    <add key="equinor-github" value="https://nuget.pkg.github.com/equinor/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
