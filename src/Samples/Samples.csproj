<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Osdu.Samples</RootNamespace>
    <AssemblyName>osdu-samples</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Equinor.OsduCsharpClient" Version="1.1.0" />
    <PackageReference Include="Equinor.Osdu.Schemas" Version="0.2.1" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration.UserSecrets" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json" CopyToOutputDirectory="PreserveNewest" />
    <None Update="appsettings.local.json" CopyToOutputDirectory="PreserveNewest" Condition="Exists('appsettings.local.json')" />
    <None Update="sample-data\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
